{
  "name": "@ecpe/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.electron.json --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "@ecpe/core": "workspace:*",
    "@ecpe/llm": "workspace:*",
    "@ecpe/schemas": "workspace:*",
    "marked": "^15.0.12",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tsconfig/svelte": "^5.0.4",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^36.5.0",
    "svelte": "^5.34.3",
    "svelte-check": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
