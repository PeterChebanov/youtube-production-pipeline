{
  "name": "video-production-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Educational Content Production Engine (ECPE)",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "ecpe": "node apps/cli/dist/index.js",
    "dev:cli": "pnpm --filter @ecpe/cli run dev",
    "dev:desktop": "pnpm --filter @ecpe/desktop run dev",
    "dev:stop": "pnpm --filter @ecpe/desktop run dev:stop",
    "desktop": "pnpm --filter @ecpe/desktop run start",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "onlyBuiltDependencies": ["ffmpeg-static", "electron", "esbuild", "puppeteer"]
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "electron": "^36.5.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  }
}
