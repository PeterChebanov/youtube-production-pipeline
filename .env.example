# Copy to .env and fill in. Keys are not committed.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Optional
# PERPLEXITY_API_KEY=

# Models (defaults apply if unset)
# Default pipeline provider: Anthropic (Claude). Override per run with --provider.
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_MAX_TOKENS=8192
# ANTHROPIC_TEMPERATURE=0.4
# GEMINI_MODEL=gemini-2.5-flash
# XAI_MODEL=grok-4-1-fast-non-reasoning  # not wired yet — adapter pending

# Base URLs
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# XAI_BASE_URL=https://api.x.ai/v1

# ECPE defaults
# ECPE_DEFAULT_PROJECTS_ROOT=~/Videos/ECPE/projects
# ECPE_ARCHIVE_ON_REGENERATE=false
# HTTP_TIMEOUT_S=300
# VISUAL_PLAN_TIMEOUT_S=600
